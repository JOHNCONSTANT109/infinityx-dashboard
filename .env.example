# MongoDB connection string (your bot's database)
  MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

  # Name of the MongoDB database your bot uses
  MONGODB_DB=infinityx

  # Secret key for session encryption (generate a random 32+ char string)
  SESSION_SECRET=your-super-secret-key-here-change-this-in-production

  # Your Vercel deployment URL
  DASHBOARD_URL=https://deezbots.vercel.app
  